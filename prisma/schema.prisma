datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Student {
  id              Int      @id @default(autoincrement())
  fullName        String
  fatherName      String
  motherName      String
  dateOfBirth     DateTime

  phone           String   @unique
  email           String   @unique
  password        String
  photo           String?



  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Parent {
  id         Int      @id @default(autoincrement())
  fullName   String
  email      String   @unique
  phone      String   @unique
  childName  String
  childClass String
  childRoll  String
  password   String
  photo      String?
  createdAt  DateTime @default(now())
}